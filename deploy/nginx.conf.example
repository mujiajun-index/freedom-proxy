# freedomProxy nginx 反向代理示例
# 用法：复制为 /etc/nginx/conf.d/freedomproxy.conf 后 `nginx -t && nginx -s reload`
# 将 proxy.example.com 替换为你的域名，并把 Node 服务监听端口对齐（默认 3000）。

upstream freedomproxy {
    server 127.0.0.1:3000;
    keepalive 32;
}

server {
    listen 443 ssl http2;
    server_name proxy.example.com;

    # --- HTTPS 证书（按实际路径填写，可用 certbot 自动生成） ---
    ssl_certificate     /etc/letsencrypt/live/proxy.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/proxy.example.com/privkey.pem;

    # --- 透传真实客户端 IP（应用层 IP 白名单 / 日志需要） ---
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # --- 流式转发：SSE / 大响应体实时回传 ---
    proxy_http_version 1.1;
    proxy_set_header   Connection "";
    proxy_buffering    off;
    proxy_read_timeout 300s;
    proxy_send_timeout 300s;

    # --- （可选）IP 白名单：在 nginx 层拦截，效率最高 ---
    # allow 192.168.1.10;
    # allow 10.0.0.0/24;
    # deny  all;

    location / {
        proxy_pass http://freedomproxy;
    }
}

# 80 跳转到 HTTPS
server {
    listen 80;
    server_name proxy.example.com;
    return 301 https://$host$request_uri;
}
