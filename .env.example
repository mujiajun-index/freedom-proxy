# freedomProxy 环境变量示例（复制为 .env 或在部署平台注入）
# 监听端口
PORT=3000

# 管理员账号（默认 admin）
ADMIN_USER=admin

# 管理员密码明文，服务启动时自动哈希；优先于 config.json 中的密码哈希
# 若不设置且 config.json 中也没有密码，首启将随机生成并打印到控制台
ADMIN_PASSWORD=

# 会话签名密钥（不设则首启随机生成并写入 config.json）
SESSION_SECRET=

# 访问日志文件路径（默认 logs/access.jsonl）
ACCESS_LOG_PATH=

# 是否信任 nginx 转发的 X-Real-IP / X-Forwarded-For（true/false）
# 经 nginx 反代时设为 true；服务直接暴露时设为 false
TRUST_PROXY=false

# config.json 存放路径（默认项目根目录）
CONFIG_PATH=
